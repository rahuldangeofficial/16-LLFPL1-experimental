-- Deep nesting stress test: plus(1, plus(2, plus(3, plus(4, plus(5, plus(6, plus(7, 8)))))))
-- Expected: 1+2+3+4+5+6+7+8 = 36
-- Under naive allocation this would need ~16 registers and hit the ceiling.
-- Under Active Register Recycling this needs at most depth+1 = 8+1 = 9 registers.
plus(1, plus(2, plus(3, plus(4, plus(5, plus(6, plus(7, 8)))))))
